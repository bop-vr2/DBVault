# ================================================================
# DBVault Railway Service — Environment Variables
# ================================================================
# Copy this file to .env for local development (never commit .env)
# Set these as environment variables in your Railway project dashboard
# ================================================================

# ── Required ─────────────────────────────────────────────────

# Secret shared between Railway and Apps Script
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-long-random-secret-here

# Google service account JSON (paste entire file content as one line)
# The service account must have Google Drive API access
# Share your Drive folder with the service account email (Editor)
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Optional ──────────────────────────────────────────────────

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info

# Port (Railway sets this automatically — do not set manually on Railway)
PORT=3000
